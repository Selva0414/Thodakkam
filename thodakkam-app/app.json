{
  "expo": {
    "name": "thodakkam-app",
    "slug": "thodakkam-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Thodakkam logo.jpeg",
    "scheme": "thodakkamapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/Thodakkam logo.jpeg"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Thodakkam logo.jpeg",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Thodakkam logo.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
            "image": "./assets/images/Thodakkam logo.jpeg",
            "backgroundColor": "#FFFFFF",
            "imageWidth": 150
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
