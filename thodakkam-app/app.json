{
  "expo": {
    "name": "Thodakkam",
    "slug": "thodakkam-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Thodakkam logo.png",
    "scheme": "thodakkamapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/Thodakkam logo.png"
    },
    "android": {
      "package": "com.thodakkam.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Thodakkam logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Thodakkam logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Thodakkam logo.png",
          "backgroundColor": "#FFFFFF",
          "imageWidth": 150
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41c97160-db4c-4fe3-a46b-6bd2921acce1"
      }
    },
    "owner": "vishnuvadhan"
  }
}
