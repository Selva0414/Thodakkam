generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Startup {
  id             String   @id @default(uuid())
  founderName    String
  companyName    String
  registrationId String
  email          String   @unique
  password       String
  category       String
  profilePhoto   String?
  role           String?  @default("Super Admin")
  timezone       String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobs               Job[]
  posts              Post[]
  followingUsers     StartupFollowsUser[]
  followers          UserFollowsStartup[]
  assessments        Assessment[]
}

model Otp {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  password     String
  phone        String?
  location     String?
  profilePhoto String?
  resumeFile   String?
  skills       String[]
  education    Json?
  experience   Json?
  portfolioUrl String?
  githubUrl    String?
  linkedinUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  applications       Application[]
  posts              Post[]
  followedStartups   UserFollowsStartup[]
  startupFollowers   StartupFollowsUser[]
}

model StartupFollowsUser {
  id        String   @id @default(uuid())
  startupId String
  startup   Startup  @relation(fields: [startupId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  @@unique([startupId, userId])
}

model UserFollowsStartup {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  startupId String
  startup   Startup  @relation(fields: [startupId], references: [id])
  createdAt DateTime @default(now())
  @@unique([userId, startupId])
}

model Post {
  id        String   @id @default(uuid())
  text      String
  imageUrl  String?
  category  String   @default("Projects")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  startupId String?
  startup   Startup? @relation(fields: [startupId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("master")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id           String   @id @default(uuid())
  title        String
  location     String
  type              String   @default("Full-time")
  salary            String?
  description       String
  requirements      String[]
  department        String?
  workMode          String?
  experience        String?
  education         String?
  openings          String?
  deadline          String?
  applicationMethod String?
  status       String   @default("ACTIVE")
  startupId    String
  startup      Startup  @relation(fields: [startupId], references: [id])
  applications Application[]
  assessments  Assessment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Application {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  fullName  String?
  email     String?
  phone     String?
  resumeUrl String?
  status        String   @default("PENDING")
  interviewDate String?
  interviewTime String?
  appliedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Assessment {
  id              String   @id @default(uuid())
  startupId       String
  startup         Startup  @relation(fields: [startupId], references: [id])
  jobId           String?
  job             Job?     @relation(fields: [jobId], references: [id])
  title           String
  description     String?
  selectedRounds  String[]
  mcqConfig       Json?
  codingConfig    Json?
  interviewConfig Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

