const getStudentAvatar = async (req, res) => {
  try {
    const studentId = req.params.studentId || req.params.id;
    const sqlQuery = `SELECT profile_photo FROM students WHERE id = $1;`;
    const { query } = require('../config/database');
    const result = await query(sqlQuery, [studentId]);
    if (!result[0] || !result[0].profile_photo) {
      return res.redirect(`https://ui-avatars.com/api/?name=Student&background=random`);
    }
    const base64Data = result[0].profile_photo;
    const matches = base64Data.match(/^data:([A-Za-z-+\/]+);base64,(.+)$/);
    if (matches && matches.length === 3) {
      const mimeType = matches[1];
      const buffer = Buffer.from(matches[2], 'base64');
      res.setHeader('Content-Type', mimeType);
      res.setHeader('Cache-Control', 'public, max-age=86400');
      return res.send(buffer);
    }
    return res.redirect(`https://ui-avatars.com/api/?name=Student&background=random`);
  } catch (error) {
    console.error('getStudentAvatar error:', error);
    res.redirect(`https://ui-avatars.com/api/?name=Student&background=random`);
// Get all assessments assigned to a student
const getStudentAssessments = async (req, res) => {
  try {
    const studentId = req.user?.id || req.params.studentId;
    if (!studentId) {
      return res.status(401).json({ error: 'Student not authenticated' });
    }

    // Check if tables exist first
    const tableCheck = await query(
      `SELECT EXISTS (
        SELECT 1 FROM information_schema.tables
        WHERE table_schema = 'public' AND table_name = 'candidate_assessments'
      ) AS exists`
    );

    if (!tableCheck[0]?.exists) {
      // Tables don't exist yet, return empty array
      return res.json({ success: true, assessments: [] });
    }

    const assessments = await query(
      `SELECT
        a.id, a.title, a.description, a.total_rounds, a.rounds, a.created_at,
        ca.status, ca.current_round, ca.mcq_score, ca.mcq_total, ca.started_at,
        s.company_name as startup_name
      FROM candidate_assessments ca
      JOIN assessments a ON a.id = ca.assessment_id
      LEFT JOIN startups s ON s.id = a.startup_id
      WHERE ca.student_id = $1
      ORDER BY ca.created_at DESC`,
      [studentId]
    );

    res.json({ success: true, assessments });
  } catch (error) {
    console.error('Get student assessments error:', error.message);
    // If table doesn't exist, return empty array instead of error
    if (error.code === '42P01') {
      return res.json({ success: true, assessments: [] });
    }
    res.status(500).json({ error: 'Failed to fetch assessments' });
  }
};

// Get questions for an assessment (student taking the test)
const getAssessmentQuestions = async (req, res) => {
  try {
    const studentId = req.user?.id;
    const assessmentId = req.params.assessmentId;

    if (!studentId) {
      return res.status(401).json({ error: 'Student not authenticated' });
    }

    // Get candidate assessment record
    const caRows = await query(
      `SELECT
        ca.id, ca.assessment_id, ca.application_id, ca.student_id, ca.current_round, ca.status,
        ca.mcq_score, ca.mcq_total, ca.mcq_completed_at,
        ca.coding_score, ca.coding_completed_at,
        ca.started_at, ca.completed_at, ca.created_at,
        a.title, a.rounds, a.total_rounds
      FROM candidate_assessments ca
      JOIN assessments a ON a.id = ca.assessment_id
      WHERE ca.student_id = $1 AND ca.assessment_id = $2`,
      [studentId, assessmentId]
    );

    if (!caRows.length) {
      return res.status(404).json({ error: 'Assessment not found or not assigned to you' });
    }

    const row = caRows[0];
    const candidateAssessment = {
      id: row.id,
      assessment_id: row.assessment_id,
      application_id: row.application_id,
      student_id: row.student_id,
      current_round: row.current_round,
      status: row.status,
      mcq_score: row.mcq_score,
      mcq_total: row.mcq_total,
      mcq_completed_at: row.mcq_completed_at,
      coding_score: row.coding_score,
      coding_completed_at: row.coding_completed_at,
      started_at: row.started_at,
      completed_at: row.completed_at,
      created_at: row.created_at,
      title: row.title,
      rounds: row.rounds || [],
      total_rounds: row.total_rounds || 0
    };

    // Check if assessment is already completed
    if (candidateAssessment.status === 'completed') {
      return res.json({
        success: true,
        isCompleted: true,
        message: 'Assessment already completed',
        scores: {
          mcq: candidateAssessment.mcq_score,
          coding: candidateAssessment.coding_score
        }
      });
    }

    // Mark as started if not already
    if (!candidateAssessment.started_at) {
      await query(
        `UPDATE candidate_assessments SET started_at = NOW(), status = 'in_progress' WHERE id = $1`,
        [candidateAssessment.id]
      );
    }

    // Get current round info
    const rounds = candidateAssessment.rounds || [];
    const currentRoundNum = candidateAssessment.current_round || 1;
    const currentRoundIndex = currentRoundNum - 1;
    const currentRound = rounds[currentRoundIndex];

    if (!currentRound) {
      console.error('Assessment round error:', {
        currentRound: currentRoundNum,
        totalRounds: rounds.length
      });
      return res.status(400).json({
        error: 'No rounds configured for this assessment',
        details: {
          currentRound: currentRoundNum,
          totalRounds: rounds.length
        }
      });
    }

    // Handle different round types
    if (currentRound.type === 'mcq') {
      // Get MCQ questions (without correct answers for security)
      // Only select columns that definitely exist
      const questions = await query(
        `SELECT id, question, options, difficulty
        FROM mcq_questions
        WHERE assessment_id = $1
        ORDER BY id ASC`,
        [assessmentId]
      );

      return res.json({
        success: true,
        roundType: 'mcq',
        assessment: {
          id: candidateAssessment.assessment_id,
          title: candidateAssessment.title,
          duration: currentRound.duration || 30
        },
        questions,
        currentRound: candidateAssessment.current_round || 1,
        totalRounds: rounds.length
      });
    } else if (currentRound.type === 'coding') {
      // Return coding round info
      return res.json({
        success: true,
        roundType: 'coding',
        assessment: {
          id: candidateAssessment.assessment_id,
          title: candidateAssessment.title,
          duration: currentRound.duration || 60
        },
        codingChallenge: {
          name: currentRound.name || 'Coding Challenge',
          description: currentRound.description || 'Complete the coding challenge below',
          language: currentRound.language || 'javascript',
          starterCode: currentRound.starterCode || '// Write your code here\n',
          testCases: currentRound.testCases || []
        },
        currentRound: candidateAssessment.current_round || 1,
        totalRounds: rounds.length
      });
    } else if (currentRound.type === 'interview') {
      let scheduledInterview = null;
      if (candidateAssessment.application_id) {
        const interviewRows = await query(
          `SELECT id, scheduled_date, time_slot, platform, interview_type, status, meet_link
          FROM interviews
          WHERE application_id = $1
          ORDER BY created_at DESC
          LIMIT 1`,
          [candidateAssessment.application_id]
        );
        scheduledInterview = interviewRows[0] || null;
      }

      // Return interview round info
      return res.json({
        success: true,
        roundType: 'interview',
        assessment: {
          id: candidateAssessment.assessment_id,
          title: candidateAssessment.title
        },
        interviewInfo: {
          name: currentRound.name || 'Interview Round',
          description: currentRound.description || 'The company will contact you to schedule an interview. Please check your email regularly.',
          status: scheduledInterview?.status || 'pending_schedule',
          message: scheduledInterview
            ? 'Your interview is scheduled. Open Interview Schedule to attend.'
            : 'Your interview will be scheduled by the company soon. Please check Interview Schedule regularly.',
          applicationId: candidateAssessment.application_id || null,
          scheduledInterview,
          interviewsPageUrl: candidateAssessment.application_id
            ? `/student/scheduled?applicationId=${candidateAssessment.application_id}`
            : '/student/scheduled'
        },
        currentRound: candidateAssessment.current_round || 1,
        totalRounds: rounds.length,
        isLastRound: true
      });
    } else {
      console.error('Unknown round type:', currentRound.type);
      return res.status(400).json({ error: `Unknown round type: ${currentRound.type}` });
    }
  } catch (error) {
    console.error('Get assessment questions error:', error.message);
    console.error('Error stack:', error.stack);
    res.status(500).json({ error: 'Failed to fetch questions', details: error.message });
  }
};

// Submit assessment responses
const submitAssessment = async (req, res) => {
  try {
    const studentId = req.user?.id;
    const assessmentId = req.params.assessmentId;
    const { responses, code, roundType } = req.body;

    if (!studentId) {
      return res.status(401).json({ error: 'Student not authenticated' });
    }

    // Get candidate assessment
    const caRows = await query(
      `SELECT ca.*, a.rounds, a.total_rounds
      FROM candidate_assessments ca
      JOIN assessments a ON a.id = ca.assessment_id
      WHERE ca.student_id = $1 AND ca.assessment_id = $2`,
      [studentId, assessmentId]
    );

    if (!caRows.length) {
      return res.status(404).json({ error: 'Assessment not found' });
    }

    const candidateAssessment = caRows[0];
    const rounds = candidateAssessment.rounds || [];
    const currentRoundNum = candidateAssessment.current_round || 1;
    const currentRoundIndex = currentRoundNum - 1;
    const currentRound = rounds[currentRoundIndex];

    let score = 0;
    let total = 0;

    // Handle MCQ round
    if (roundType === 'mcq') {
      const hasPointsColumn = await columnExists('mcq_questions', 'points');
      const hasCorrectAnswerColumn = await columnExists('mcq_questions', 'correct_answer');
      const hasCorrectOptionIndexColumn = hasCorrectAnswerColumn
        ? false
        : await columnExists('mcq_questions', 'correct_option_index');

      if (!hasCorrectAnswerColumn && !hasCorrectOptionIndexColumn) {
        return res.status(500).json({
          error: 'Assessment question schema is missing answer key column',
          details: 'Expected mcq_questions.correct_answer or mcq_questions.correct_option_index'
        });
      }

      const correctAnswerColumn = hasCorrectAnswerColumn ? 'correct_answer' : 'correct_option_index';
      const pointsSelect = hasPointsColumn ? 'COALESCE(points, 1) AS points' : '1 AS points';

      const questions = await query(
        `SELECT id, ${correctAnswerColumn} AS correct_answer, ${pointsSelect}
        FROM mcq_questions
        WHERE assessment_id = $1`,
        [assessmentId]
      );

      const responseList = Array.isArray(responses) ? responses : [];

      const answerMap = {};
      questions.forEach(q => { answerMap[q.id] = q; });

      for (const response of responseList) {
        const questionId = Number(response?.question_id);
        const selectedOption = response?.selected_option;
        const question = Number.isInteger(questionId) ? answerMap[questionId] : null;

        if (question) {
          total += question.points || 1;
          const isCorrect = selectedOption === question.correct_answer;
          if (isCorrect) {
            score += question.points || 1;
          }

          // Save response only when student selected an option.
          // This avoids NULL insert issues on environments with stricter legacy schemas.
          if (selectedOption !== null && selectedOption !== undefined) {
            await query(
              `INSERT INTO mcq_responses (candidate_assessment_id, question_id, selected_option, is_correct)
              VALUES ($1, $2, $3, $4)
              ON CONFLICT DO NOTHING`,
              [candidateAssessment.id, questionId, selectedOption, isCorrect]
            );
          }
        }
      }

      // Update MCQ scores
      await query(
        `UPDATE candidate_assessments
        SET mcq_score = $1, mcq_total = $2, mcq_completed_at = NOW()
        WHERE id = $3`,
        [score, total, candidateAssessment.id]
      );
    }

    // Handle Coding round
    if (roundType === 'coding' && code) {
      // For now, just mark coding as completed (evaluation would be done separately)
      await query(
        `UPDATE candidate_assessments
        SET coding_score = 100, coding_completed_at = NOW()
        WHERE id = $1`,
        [candidateAssessment.id]
      );
      score = 100;
      total = 100;
    }

    // Move to next round
    const nextRound = currentRoundNum + 1;
    const isLastRound = nextRound > rounds.length;

    let newStatus = 'in_progress';
    if (isLastRound) {
      newStatus = 'completed';
    }

    await query(
      `UPDATE candidate_assessments
      SET current_round = $1, status = $2,
          completed_at = CASE WHEN $3::text = 'completed' THEN NOW() ELSE completed_at END
      WHERE id = $4`,
      [isLastRound ? currentRoundNum : nextRound, newStatus, newStatus, candidateAssessment.id]
    );

    res.json({
      success: true,
      message: 'Round submitted successfully',
      score,
      total,
      currentRound: currentRoundNum,
      nextRound: isLastRound ? null : nextRound,
      isCompleted: isLastRound
    });
  } catch (error) {
    console.error('Submit assessment error:', {
      message: error.message,
      code: error.code,
      detail: error.detail
    });
    res.status(500).json({
      error: 'Failed to submit assessment',
      details: error.message
    });
  }
};

// Run code without submitting (for testing)
const runCode = async (req, res) => {
  try {
    const { code, language, testCases } = req.body;

    if (!code) {
      return res.status(400).json({ error: 'Code is required' });
    }

    // If test cases provided, run against them
    if (testCases && testCases.length > 0) {
      const results = await runTestCases(language || 'javascript', code, testCases);
      return res.json({
        success: true,
        ...results
      });
    }

    // Otherwise just execute the code
    const result = await executeCode(language || 'javascript', code, '');

    res.json({
      success: result.success,
      output: result.output,
      error: result.error,
      compileError: result.compileError
    });
  } catch (error) {
    console.error('Run code error:', error.message);
    res.status(500).json({ error: 'Failed to execute code' });
  }
};

// Submit code for assessment (run against all test cases and score)
const submitCode = async (req, res) => {
  try {
    const studentId = req.user?.id;
    const assessmentId = req.params.assessmentId;
    const { code, language } = req.body;

    if (!studentId) {
      return res.status(401).json({ error: 'Student not authenticated' });
    }

    // Get candidate assessment and coding challenge details
    const caRows = await query(
      `SELECT ca.*, a.rounds, a.total_rounds
      FROM candidate_assessments ca
      JOIN assessments a ON a.id = ca.assessment_id
      WHERE ca.student_id = $1 AND ca.assessment_id = $2`,
      [studentId, assessmentId]
    );

    if (!caRows.length) {
      return res.status(404).json({ error: 'Assessment not found' });
    }

    const candidateAssessment = caRows[0];
    const rounds = candidateAssessment.rounds || [];
    const currentRoundNum = candidateAssessment.current_round || 1;
    const currentRound = rounds[currentRoundNum - 1];

    if (!currentRound || currentRound.type !== 'coding') {
      return res.status(400).json({ error: 'Current round is not a coding round' });
    }

    const testCases = currentRound.testCases || [];
    let score = 0;
    let total = 100;
    let testResults = null;

    // Run code against test cases
    if (testCases.length > 0) {
      testResults = await runTestCases(language || currentRound.language || 'javascript', code, testCases);
      score = testResults.summary.score;
    } else {
      // No test cases, just check if code runs
      const execResult = await executeCode(language || 'javascript', code, '');
      score = execResult.success ? 100 : 0;
    }

    // Update coding score
    await query(
      `UPDATE candidate_assessments
      SET coding_score = $1, coding_completed_at = NOW()
      WHERE id = $2`,
      [score, candidateAssessment.id]
    );

    // Move to next round
    const nextRound = currentRoundNum + 1;
    const isLastRound = nextRound > rounds.length;

    let newStatus = 'in_progress';
    if (isLastRound) {
      newStatus = 'completed';
    }

    await query(
      `UPDATE candidate_assessments
      SET current_round = $1, status = $2,
          completed_at = CASE WHEN $2 = 'completed' THEN NOW() ELSE completed_at END
      WHERE id = $3`,
      [isLastRound ? currentRoundNum : nextRound, newStatus, candidateAssessment.id]
    );

    res.json({
      success: true,
      message: 'Code submitted successfully',
      score,
      total,
      testResults: testResults?.results || null,
      summary: testResults?.summary || { passed: score === 100 ? 1 : 0, total: 1 },
      currentRound: currentRoundNum,
      nextRound: isLastRound ? null : nextRound,
      isCompleted: isLastRound
    });
  } catch (error) {
    console.error('Submit code error:', error.message);
    res.status(500).json({ error: 'Failed to submit code' });
  }
};

module.exports = {
  registerStudent,
  loginStudent,
  getDashboard,
  getStudentProfile,
  searchStudents,
  updateStudentProfile,
  getStudentAvatar,
  getStudentAssessments,
  getAssessmentQuestions,
  submitAssessment,
  runCode,
  submitCode,
};
